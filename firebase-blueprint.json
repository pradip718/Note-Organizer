{
  "entities": {
    "Note": {
      "title": "Note",
      "description": "A user's note document",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the owner"
        },
        "title": {
          "type": "string",
          "description": "Note title"
        },
        "content": {
          "type": "string",
          "description": "Note content"
        },
        "tags": {
          "type": "array",
          "description": "List of tags"
        },
        "layout": {
          "type": "string",
          "description": "Preferred layout (standard or kanban)",
          "enum": ["standard", "kanban"]
        },
        "kanbanData": {
          "type": "object",
          "description": "Data for kanban layout"
        },
        "updatedAt": {
          "type": "number",
          "description": "Timestamp of last update"
        },
        "createdAt": {
          "type": "number",
          "description": "Timestamp of creation"
        }
      },
      "required": ["userId", "title", "content", "tags", "updatedAt", "createdAt"]
    }
  },
  "firestore": {
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "Global notes collection restricted by userId"
    }
  }
}
